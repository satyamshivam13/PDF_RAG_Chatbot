# Template for Streamlit secrets.
#
# Local dev:  copy this file to `.streamlit/secrets.toml` and fill in your key
#             (secrets.toml is git-ignored and must never be committed).
# Cloud:      paste the same contents into the Streamlit Community Cloud
#             app's  Settings -> Secrets  box.

GROQ_API_KEY = "your_groq_api_key_here"

# Optional overrides (defaults shown):
# LLM_MODEL = "llama-3.1-8b-instant"
# LLM_BASE_URL = "https://api.groq.com/openai/v1"
